# =============================================================================
# OpenClaw + Telegram — Copiar a .env y rellenar valores
# =============================================================================

# --- Telegram (canal nativo de OpenClaw) ---
# Token del bot: crear en @BotFather, pegar aquí
TELEGRAM_BOT_TOKEN=

# IDs de usuario de Telegram permitidos (separados por coma, sin espacios)
# Obtener tu ID: enviar /start a @userinfobot en Telegram
OPENCLAW_ALLOW_FROM=

# --- Gateway OpenClaw ---
# Token para la Control UI (http://localhost:18789). Generar uno seguro o dejar vacío para que OpenClaw lo gestione
OPENCLAW_GATEWAY_TOKEN=

# --- Claves de proveedores LLM ---
# Principal: OpenRouter (una sola key para muchos modelos: Claude, GPT, etc.)
OPENROUTER_API_KEY=

# Opcionales: para usar proveedores directos más adelante
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# MISTRAL_API_KEY=
# COHERE_API_KEY=

# --- Opcional: logging y puertos ---
# OPENCLAW_LOG_LEVEL=info
# OPENCLAW_API_PORT=8080
# OPENCLAW_WS_PORT=8081
